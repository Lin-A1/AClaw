# LLM 配置
MODEL_NAME=MiniMax-M2.7
MODEL_URL=https://api.minimaxi.com/v1
MODEL_APIKEY=your-api-key-here

# Agent 运行时参数
MAX_TOKENS=4096
TEMPERATURE=1.0
SYSTEM_PROMPT=You are a helpful AI assistant.

# 日志级别 (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO

# API Server (可选)
API_HOST=0.0.0.0
API_PORT=18000
